<launch>
    <let name="puzzlebot_gazebo_launch_path" value="$(find-pkg-share puzzlebot_gazebo)/launch/puzzlebot_gazebo.launch.xml"/>
    <let name="nav2_core_launch_path" value="$(find-pkg-share puzzlebot_navigation2)/launch/nav2_core.launch.xml" />
    <let name="nav2_rviz_config_path" value="$(find-pkg-share puzzlebot_navigation2)/rviz/nav2.rviz" />
    <arg name="use_sim_time" default="true" />
    <arg name="headless" default="true" />
    <arg name="map_path" default="$(find-pkg-share puzzlebot_navigation2)/maps/map_maze.yaml" />

    <include file="$(var nav2_core_launch_path)" >
        <arg name="map_path" value="$(var headless)" />
    </include>

    <include file="$(find-pkg-source puzzlebot_navigation2)/launch/nav2_core.launch.xml">
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
        <arg name="nav2_params_file" value="$(var nav2_params_file)"/>
        <arg name="map_path" default="$(find-pkg-share puzzlebot_navigation2)/maps/my_maze.yaml"/>
        <arg name="nav2_params_file" value="$(var nav2_params_file)"/>
    </include>
</launch>