<launch>
    <arg name="map_path" default="$(find-pkg-share puzzlebot_navigation2)/maps/my_maze.yaml" />
    <arg name="nav2_params_file" default="$(find-pkg-share puzzlebot_navigation2)/config/nav2_params.yaml" />
    <arg name="rvizz_config_path" default="$(find-pkg-share puzzlebot_navigation2)/rviz/nav2.rviz"/>
    <arg name="use_sim_time" default="true" />

    <include file="$(find-pkg-share nav2_bringup)/launch/bringup.launch.py">
        <arg name="map" value="$(var map)"/>
        <arg name="rviz_config_path" value="file=$(find-pkg-source puzzlebot_navigation2)/rviz/slam.rviz"/>
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
        <arg name="params_file" value="file=$(find-pkg-source puzzlebot_navigation2)/config/nav2_params.yaml"/>
    </include>

    <node pkg="rviz2" exec="rviz2" name="rviz2" output="screen" args="-d $(var rviz_config_path)">
        <param name="use_sim_time" value="$(var use_sim_time)" />

    </node>
   
</launch>