<launch>
    <arg name="slam_params_file" default="$(find-pkg-share puzzlebot_navigation2)/config/slam_toolbox.yaml" />
    <arg name="rviz_config_path" default="$(find-pkg-share puzzlebot_navigation2)/rviz/slam.rviz" />
    <arg name="use_sim_time" default="true" />
    <arg name="launch_teleop" default="false" />
    <arg name="teleop_use_xterm" default="false" />

    <node pkg="slam_toolbox" exec="async_slam_toolbox_node"
          name="slam_toolbox" output="screen">
        <param name="use_sim_time" value="$(var use_sim_time)" />
        <param from="$(var slam_params_file)" />
    </node>

    <node pkg="rviz2" exec="rviz2" name="rviz2"
          output="screen" args="-d $(var rviz_config_path)">
        <param name="use_sim_time" value="$(var use_sim_time)" />
    </node>

    <group if="$(var launch_teleop)">
        <node pkg="teleop_twist_keyboard"
              exec="teleop_twist_keyboard"
              name="teleop_twist_keyboard"
              output="screen"
              if="$(not $(var teleop_use_xterm))">
            <param name="use_sim_time" value="$(var use_sim_time)" />
        </node>

        <node pkg="teleop_twist_keyboard"
              exec="teleop_twist_keyboard"
              name="teleop_twist_keyboard_xterm"
              output="screen"
              if="$(var teleop_use_xterm)"
              launch-prefix="xterm -e">
            <param name="use_sim_time" value="$(var use_sim_time)" />
        </node>
    </group>

</launch>