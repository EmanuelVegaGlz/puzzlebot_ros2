<launch>

    <let name="world" value="$(find-pkg-share puzzlebot_gazebo)/worlds/empty_with_sensors.sdf"/>
    <let name="maze_model_path" value="$(find-pkg-share puzzlebot_gazebo)/worlds/maze_world.world/model.sdf"/>
    <let name="puzzlebot_description_path" value="$(find-pkg-share puzzlebot_description)/launch/puzzlebot_description.launch.xml"/>
    <let name="puzzlebot_bridge_config_path" value="$(find-pkg-share puzzlebot_gazebo)/config/gazebo_bridge.yaml"/>
    <let name="gz_sim_launch_path" value="$(find-pkg-share ros_gz_sim)/launch/gz_sim.launch.py"/>

    <let name="x_pose" value="1.35"/>
    <let name="y_pose" value="0.0"/>

    <arg name="use_sim_time" default="true"/>
    <arg name="headless" default="false"/>

    <!-- Gazebo con GUI -->
    <include if="$(not $(var headless))" file="$(var gz_sim_launch_path)">
        <arg name="gz_args" value="$(var world) -r"/>
    </include>

    <!-- Gazebo sin GUI -->
    <include if="$(var headless)" file="$(var gz_sim_launch_path)">
        <arg name="gz_args" value="$(var world) -r -s"/>
    </include>

    <!-- Robot description -->
    <include file="$(var puzzlebot_description_path)">
        <arg name="use_sim_time" value="$(var use_sim_time)"/>
    </include>

    <!-- Spawn maze model into the empty world -->
    <node pkg="ros_gz_sim" exec="create" output="screen"
          args="-name maze_walls -file $(var maze_model_path)"/>

    <!-- Spawn robot -->
    <node pkg="ros_gz_sim" exec="create" output="screen"
          args="-name puzzlebot -topic robot_description -x $(var x_pose) -y $(var y_pose) -z 0.01 -Y 3.1416"/>

    <!-- Bridge -->
    <node pkg="ros_gz_bridge" exec="parameter_bridge" output="screen">
        <param name="config_file" value="$(var puzzlebot_bridge_config_path)"/>
    </node>

    <!-- Align Gazebo lidar frame naming with the robot TF tree -->
    <node pkg="tf2_ros" exec="static_transform_publisher" output="screen"
          args="0.08 0 0.15 0 0 0 base_footprint puzzlebot/base_footprint/laser"/>

</launch>